{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "tax-strategy.html", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/tax-strategy", "dest": "/tax-strategy.html" },
    { "src": "/tax-strategy.html", "dest": "/tax-strategy.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
